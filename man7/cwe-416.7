.SH EXAMPLES
One vulnerable\->fixed pair per ecosystem (C, C++).
.SS C
\fIVulnerable:\fR
.RS
.EX
char *p = malloc(32);
free(p);
strcpy(p, "late");   /* dangling: use-after-free (and a later double free) */
.EE
.RE
\fIFixed:\fR
.RS
.EX
char *p = malloc(32);
if (!p) return;
/* ... use p ... */
free(p);
p = NULL;            /* dangling pointer can no longer be dereferenced */
.EE
.RE
.SS C++
\fIVulnerable:\fR
.RS
.EX
int *p = new int(42);
delete p;
std::cout << *p;     // use-after-free
.EE
.RE
\fIFixed:\fR
.RS
.EX
auto p = std::make_unique<int>(42);   // ownership clear; freed at scope end
std::cout << *p;
.EE
.RE
